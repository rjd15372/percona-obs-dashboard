# OBS credentials (required)
OBS_USERNAME=
OBS_PASSWORD=
OBS_BASE_URL=https://api.opensuse.org

# RabbitMQ
MQ_URL=amqps://opensuse:opensuse@rabbit.opensuse.org:5671/

# Poller
POLL_INTERVAL=5m

# Storage
DB_PATH=/data/obsboard.db
EVENT_RETENTION=7d

# Server
HTTP_PORT=8080
FRONTEND_DIR=
CONFIG_FILE=./config.yaml
